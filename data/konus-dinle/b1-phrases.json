{
  "version": "1",
  "phrases": [
    { "id": "b1_001", "textDe": "Ich finde das interessant.", "textTr": "Bunu ilginç buluyorum." },
    { "id": "b1_002", "textDe": "Kannst du mir helfen?", "textTr": "Bana yardım edebilir misin?" },
    { "id": "b1_003", "textDe": "Ich habe keine Zeit.", "textTr": "Vaktim yok." },
    { "id": "b1_004", "textDe": "Das ist eine gute Idee.", "textTr": "Bu iyi bir fikir." },
    { "id": "b1_005", "textDe": "Ich bin damit einverstanden.", "textTr": "Buna katılıyorum." },
    { "id": "b1_006", "textDe": "Es tut mir leid.", "textTr": "Üzgünüm." },
    { "id": "b1_007", "textDe": "Ich warte auf den Bus.", "textTr": "Otobüsü bekliyorum." },
    { "id": "b1_008", "textDe": "Wir treffen uns morgen.", "textTr": "Yarın buluşuyoruz." },
    { "id": "b1_009", "textDe": "Ich muss jetzt gehen.", "textTr": "Şimdi gitmem lazım." },
    { "id": "b1_010", "textDe": "Das Wetter ist heute schön.", "textTr": "Bugün hava güzel." },
    { "id": "b1_011", "textDe": "Ich interessiere mich für Musik.", "textTr": "Müzikle ilgileniyorum." },
    { "id": "b1_012", "textDe": "Können Sie das wiederholen?", "textTr": "Tekrar eder misiniz?" },
    { "id": "b1_013", "textDe": "Ich bin seit drei Jahren hier.", "textTr": "Üç yıldır buradayım." },
    { "id": "b1_014", "textDe": "Das habe ich nicht verstanden.", "textTr": "Bunu anlamadım." },
    { "id": "b1_015", "textDe": "Ich freue mich auf dich.", "textTr": "Seni görmeyi dört gözle bekliyorum." },
    { "id": "b1_016", "textDe": "Er arbeitet in einer Fabrik.", "textTr": "Bir fabrikada çalışıyor." },
    { "id": "b1_017", "textDe": "Wir fahren in den Urlaub.", "textTr": "Tatile gidiyoruz." },
    { "id": "b1_018", "textDe": "Ich brauche mehr Informationen.", "textTr": "Daha fazla bilgiye ihtiyacım var." },
    { "id": "b1_019", "textDe": "Sie spricht sehr gut Deutsch.", "textTr": "Çok iyi Almanca konuşuyor." },
    { "id": "b1_020", "textDe": "Ich habe gestern Fußball gesehen.", "textTr": "Dün futbol izledim." },
    { "id": "b1_021", "textDe": "Das ist mir zu teuer.", "textTr": "Bu benim için çok pahalı." },
    { "id": "b1_022", "textDe": "Ich wohne allein in Berlin.", "textTr": "Berlin'de yalnız yaşıyorum." },
    { "id": "b1_023", "textDe": "Wir haben viel zu tun.", "textTr": "Yapacak çok işimiz var." },
    { "id": "b1_024", "textDe": "Ich lerne Deutsch weil ich arbeite.", "textTr": "Çalıştığım için Almanca öğreniyorum." },
    { "id": "b1_025", "textDe": "Kann ich bitte bezahlen?", "textTr": "Ödeyebilir miyim lütfen?" },
    { "id": "b1_026", "textDe": "Mein Handy ist kaputt.", "textTr": "Telefonum bozuk." },
    { "id": "b1_027", "textDe": "Ich bin mit dem Ergebnis zufrieden.", "textTr": "Sonuçtan memnunum." },
    { "id": "b1_028", "textDe": "Wir essen oft zusammen.", "textTr": "Sık sık birlikte yemek yeriz." },
    { "id": "b1_029", "textDe": "Er kommt aus der Türkei.", "textTr": "Türkiye'den geliyor." },
    { "id": "b1_030", "textDe": "Ich habe Kopfschmerzen heute.", "textTr": "Bugün baş ağrım var." },
    { "id": "b1_031", "textDe": "Das Restaurant ist sehr beliebt.", "textTr": "Restoran çok popüler." },
    { "id": "b1_032", "textDe": "Ich möchte einen Termin vereinbaren.", "textTr": "Randevu almak istiyorum." },
    { "id": "b1_033", "textDe": "Sie fährt jeden Tag zur Arbeit.", "textTr": "Her gün işe gidiyor." },
    { "id": "b1_034", "textDe": "Wir sprechen über die Zukunft.", "textTr": "Gelecek hakkında konuşuyoruz." },
    { "id": "b1_035", "textDe": "Ich kann leider nicht kommen.", "textTr": "Maalesef gelemem." },
    { "id": "b1_036", "textDe": "Er hat die Prüfung bestanden.", "textTr": "Sınavı geçti." },
    { "id": "b1_037", "textDe": "Ich suche eine neue Wohnung.", "textTr": "Yeni bir daire arıyorum." },
    { "id": "b1_038", "textDe": "Das Konzert war wirklich toll.", "textTr": "Konser gerçekten harikaydı." },
    { "id": "b1_039", "textDe": "Wir planen eine Reise nach Wien.", "textTr": "Viyana'ya bir gezi planlıyoruz." },
    { "id": "b1_040", "textDe": "Ich bin noch nicht fertig.", "textTr": "Henüz bitirmedim." }
  ]
}
