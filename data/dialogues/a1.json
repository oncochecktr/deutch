[
  {
    "id": "d_a1_01",
    "level": "A1",
    "title_de": "Tims kleine Frage",
    "title_tr": "Tim'in küçük sorusu",
    "theme": "Komik · Familie · Fußball",
    "source": "seed",
    "lines": [
      { "id": "l01", "kind": "narration", "text_de": "Tim und sein Papa sind zu Hause. Papa sitzt vor dem Fernseher.", "text_tr": "Tim ve babası evde. Baba televizyonun önünde oturuyor." },
      { "id": "l02", "speaker": "Tim", "kind": "dialogue", "text_de": "Papa, eine kleine Frage.", "text_tr": "Baba, küçük bir sorum var." },
      { "id": "l03", "speaker": "Papa", "kind": "dialogue", "text_de": "Es tut mir leid, Tim. Ich kann jetzt nicht.", "text_tr": "Üzgünüm Tim. Şimdi yapamam." },
      { "id": "l04", "speaker": "Papa", "kind": "dialogue", "text_de": "Das Fußballspiel ist sehr aufregend.", "text_tr": "Futbol maçı çok heyecanlı." },
      { "id": "l05", "speaker": "Papa", "kind": "dialogue", "text_de": "Ja! Da drüben! Komm!", "text_tr": "Evet! Orada! Gel!" },
      { "id": "l06", "speaker": "Tim", "kind": "dialogue", "text_de": "Ich brauche Geld…", "text_tr": "Paraya ihtiyacım var…" },
      { "id": "l07", "speaker": "Papa", "kind": "dialogue", "text_de": "Ja!", "text_tr": "Evet!" },
      { "id": "l08", "speaker": "Tim", "kind": "dialogue", "text_de": "Wirklich?", "text_tr": "Gerçekten mi?" },
      { "id": "l09", "speaker": "Tim", "kind": "dialogue", "text_de": "Ich möchte eine Pizza bestellen.", "text_tr": "Pizza sipariş etmek istiyorum." },
      { "id": "l10", "speaker": "Papa", "kind": "dialogue", "text_de": "Schnell! Komm! Ja! Jetzt!", "text_tr": "Çabuk! Gel! Evet! Hemen!" },
      { "id": "l11", "speaker": "Tim", "kind": "dialogue", "text_de": "Und ich möchte ein neues Videospiel.", "text_tr": "Ve yeni bir video oyunu istiyorum." },
      { "id": "l12", "speaker": "Papa", "kind": "dialogue", "text_de": "Ja!", "text_tr": "Evet!" },
      { "id": "l13", "speaker": "Tim", "kind": "dialogue", "text_de": "Und ich gehe am Montag nicht in die Schule!", "text_tr": "Ve pazartesi okula gitmeyeceğim!" },
      { "id": "l14", "speaker": "Papa", "kind": "dialogue", "text_de": "Ja! Super!", "text_tr": "Evet! Süper!" },
      { "id": "l15", "speaker": "Tim", "kind": "dialogue", "text_de": "Cool, das ist einfach!", "text_tr": "Harika, bu çok kolay!" },
      { "id": "l16", "speaker": "Tim", "kind": "dialogue", "text_de": "Ich gehe jetzt in das Kaufhaus!", "text_tr": "Şimdi alışveriş merkezine gidiyorum!" },
      { "id": "l17", "speaker": "Papa", "kind": "dialogue", "text_de": "Ja! Ja! Ja!", "text_tr": "Evet! Evet! Evet!" },
      { "id": "l18", "speaker": "Tim", "kind": "dialogue", "text_de": "Bis später, Papa!", "text_tr": "Sonra görüşürüz baba!" },
      { "id": "l19", "kind": "narration", "text_de": "Das Fußballspiel ist vorbei. Papa schaut sich um.", "text_tr": "Futbol maçı bitti. Baba etrafına bakınıyor." },
      { "id": "l20", "speaker": "Papa", "kind": "dialogue", "text_de": "OK… was möchtest du, Tim?", "text_tr": "Tamam… ne istiyorsun Tim?" },
      { "id": "l21", "speaker": "Papa", "kind": "dialogue", "text_de": "Tim? Wo bist du?", "text_tr": "Tim? Neredesin?" }
    ],
    "comprehension": [
      {
        "id": "c01",
        "prompt_tr": "Tim'in babası kendini neye o kadar kaptırmıştı ki Tim'i duymadı?",
        "options_tr": ["Pizza siparişine", "Futbol maçına", "Video oyununa", "Okula"],
        "correct_index": 1,
        "explanation_tr": "Papa sagt: Das Fußballspiel ist sehr aufregend."
      },
      {
        "id": "c02",
        "prompt_tr": "Tim en son nereye gitmeye karar verdi?",
        "options_tr": ["Okula", "Fußballplatz", "Kaufhaus", "Pizzeria"],
        "correct_index": 2
      },
      {
        "id": "c03",
        "prompt_tr": "Papa maç bitince ne soruyor?",
        "options_tr": ["Wo ist die Pizza?", "Was möchtest du?", "Wann ist Schule?", "Wer spielt Fußball?"],
        "correct_index": 1
      }
    ]
  },
  {
    "id": "d_a1_02",
    "level": "A1",
    "title_de": "Im Supermarkt",
    "title_tr": "Süpermarkette",
    "theme": "Einkaufen · Zahlen",
    "source": "seed",
    "lines": [
      { "id": "l01", "speaker": "Kunde", "kind": "dialogue", "text_de": "Guten Tag! Ich suche Milch.", "text_tr": "İyi günler! Süt arıyorum." },
      { "id": "l02", "speaker": "Verkäuferin", "kind": "dialogue", "text_de": "Die Milch ist dort, links.", "text_tr": "Süt orada, solda." },
      { "id": "l03", "speaker": "Kunde", "kind": "dialogue", "text_de": "Danke. Ich brauche auch Brot.", "text_tr": "Teşekkürler. Ekmek de lazım." },
      { "id": "l04", "speaker": "Verkäuferin", "kind": "dialogue", "text_de": "Das Brot kostet zwei Euro.", "text_tr": "Ekmek iki euro." },
      { "id": "l05", "speaker": "Kunde", "kind": "dialogue", "text_de": "Und die Milch?", "text_tr": "Süt ne kadar?" },
      { "id": "l06", "speaker": "Verkäuferin", "kind": "dialogue", "text_de": "Eins Euro fünfzig.", "text_tr": "Bir euro elli." },
      { "id": "l07", "speaker": "Kunde", "kind": "dialogue", "text_de": "Gut. Ich nehme beides.", "text_tr": "Tamam. İkisini de alıyorum." },
      { "id": "l08", "speaker": "Verkäuferin", "kind": "dialogue", "text_de": "Das macht drei Euro fünfzig.", "text_tr": "Toplam üç euro elli." },
      { "id": "l09", "speaker": "Kunde", "kind": "dialogue", "text_de": "Hier, bitte.", "text_tr": "Buyurun." },
      { "id": "l10", "speaker": "Verkäuferin", "kind": "dialogue", "text_de": "Danke! Schönen Tag noch!", "text_tr": "Teşekkürler! İyi günler!" }
    ],
    "comprehension": [
      {
        "id": "c01",
        "prompt_tr": "Müşteri ne arıyor?",
        "options_tr": ["Brot", "Milch", "Käse", "Wasser"],
        "correct_index": 1
      },
      {
        "id": "c02",
        "prompt_tr": "Toplam ne kadar?",
        "options_tr": ["2,50 €", "3,50 €", "4,00 €", "1,50 €"],
        "correct_index": 1
      }
    ]
  },
