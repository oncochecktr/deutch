      { "id": "l05", "speaker": "Lehrer", "kind": "dialogue", "text_de": "Gut. Heute lernen wir Zahlen.", "text_tr": "Güzel. Bugün sayıları öğreniyoruz." },
      { "id": "l06", "speaker": "Lehrer", "kind": "dialogue", "text_de": "Öffnet bitte das Buch auf Seite zehn.", "text_tr": "Lütfen kitabı onuncu sayfada açın." },
      { "id": "l07", "speaker": "Max", "kind": "dialogue", "text_de": "Entschuldigung, ich habe mein Buch vergessen.", "text_tr": "Özür dilerim, kitabımı unuttum." },
      { "id": "l08", "speaker": "Lehrer", "kind": "dialogue", "text_de": "Kein Problem. Schau mit Anna.", "text_tr": "Sorun değil. Anna ile bak." },
      { "id": "l09", "kind": "narration", "text_de": "Die Stunde beginnt um acht Uhr.", "text_tr": "Ders saat sekizde başlıyor." }
    ],
    "comprehension": [
