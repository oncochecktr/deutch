      { "id": "l01", "speaker": "Aylin", "kind": "dialogue", "text_de": "Hallo! Ich heiße Aylin.", "text_tr": "Merhaba! Benim adım Aylin." },
      { "id": "l02", "speaker": "Tom", "kind": "dialogue", "text_de": "Hi! Ich bin Tom. Woher kommst du?", "text_tr": "Selam! Ben Tom. Nerelisin?" },
      { "id": "l03", "speaker": "Aylin", "kind": "dialogue", "text_de": "Ich komme aus der Türkei.", "text_tr": "Türkiye'den geliyorum." },
      { "id": "l04", "speaker": "Aylin", "kind": "dialogue", "text_de": "Ich wohne in Berlin mit meiner Familie.", "text_tr": "Berlin'de ailemle yaşıyorum." },
      { "id": "l05", "speaker": "Tom", "kind": "dialogue", "text_de": "Wie groß ist deine Familie?", "text_tr": "Ailen kaç kişi?" },
      { "id": "l06", "speaker": "Aylin", "kind": "dialogue", "text_de": "Ich habe einen Bruder und eine Schwester.", "text_tr": "Bir erkek kardeşim ve bir kız kardeşim var." },
      { "id": "l07", "speaker": "Tom", "kind": "dialogue", "text_de": "Schön! Meine Familie ist klein.", "text_tr": "Güzel! Benim ailem küçük." },
      { "id": "l08", "speaker": "Tom", "kind": "dialogue", "text_de": "Nur meine Mutter und ich.", "text_tr": "Sadece annem ve ben." }
    ],
