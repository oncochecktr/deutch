    "theme": "Reisen · Beschwerde",
    "source": "seed",
    "lines": [
      { "id": "l01", "speaker": "Gast", "kind": "dialogue", "text_de": "Guten Abend. Ich habe ein Problem mit dem Zimmer.", "text_tr": "İyi akşamlar. Oda ile ilgili bir sorunum var." },
      { "id": "l02", "speaker": "Rezeption", "kind": "dialogue", "text_de": "Was ist los?", "text_tr": "Ne oldu?" },
      { "id": "l03", "speaker": "Gast", "kind": "dialogue", "text_de": "Die Heizung funktioniert nicht.", "text_tr": "Kalorifer çalışmıyor." },
      { "id": "l04", "speaker": "Rezeption", "kind": "dialogue", "text_de": "Es tut mir leid. Wir schicken sofort jemanden.", "text_tr": "Özür dileriz. Hemen birini gönderiyoruz." },
      { "id": "l05", "speaker": "Gast", "kind": "dialogue", "text_de": "Danke. Wann kommt der Techniker?", "text_tr": "Teşekkürler. Teknisyen ne zaman gelir?" },
      { "id": "l06", "speaker": "Rezeption", "kind": "dialogue", "text_de": "In zehn Minuten.", "text_tr": "On dakika içinde." }
    ],
    "comprehension": [
      { "id": "c01", "prompt_tr": "Sorun ne?", "options_tr": ["TV", "Heizung", "Dusche", "Fenster"], "correct_index": 1 }
    ]
  },
  {
