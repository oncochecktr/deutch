      { "id": "l02", "speaker": "Paul", "kind": "dialogue", "text_de": "Ich bin nach Hamburg gefahren.", "text_tr": "Hamburg'a gittim." },
      { "id": "l03", "speaker": "Lena", "kind": "dialogue", "text_de": "Allein oder mit Freunden?", "text_tr": "Yalnız mı arkadaşlarla mı?" },
      { "id": "l04", "speaker": "Paul", "kind": "dialogue", "text_de": "Mit meinem Bruder. Wir haben den Hafen besucht.", "text_tr": "Erkek kardeşimle. Limanı gezdik." },
      { "id": "l05", "speaker": "Lena", "kind": "dialogue", "text_de": "War es schön?", "text_tr": "Güzel miydi?" },
      { "id": "l06", "speaker": "Paul", "kind": "dialogue", "text_de": "Ja, sehr! Das Wetter war gut.", "text_tr": "Evet, çok! Hava güzeldi." }
