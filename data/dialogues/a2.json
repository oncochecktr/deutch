    "source": "seed",
    "lines": [
      { "id": "l01", "speaker": "Sara", "kind": "dialogue", "text_de": "Es regnet seit dem Morgen.", "text_tr": "Sabahdan beri yağmur yağıyor." },
      { "id": "l02", "speaker": "Jonas", "kind": "dialogue", "text_de": "Schade! Wir wollten spazieren gehen.", "text_tr": "Yazık! Yürüyüşe çıkmak istiyorduk." },
      { "id": "l03", "speaker": "Sara", "kind": "dialogue", "text_de": "Gehen wir ins Kino?", "text_tr": "Sinemaya gidelim mi?" },
      { "id": "l04", "speaker": "Jonas", "kind": "dialogue", "text_de": "Gute Idee! Ich habe schon lange keinen Film gesehen.", "text_tr": "İyi fikir! Uzun zamandır film izlemedim." },
      { "id": "l05", "speaker": "Sara", "kind": "dialogue", "text_de": "Der Film beginnt um sieben Uhr.", "text_tr": "Film saat yedide başlıyor." },
      { "id": "l06", "speaker": "Jonas", "kind": "dialogue", "text_de": "Perfekt, dann treffen wir uns um halb sieben.", "text_tr": "Mükemmel, o zaman altı buçukta buluşalım." }
    ],
    "comprehension": [
      { "id": "c01", "prompt_tr": "Hava nasıl?", "options_tr": ["Güneşli", "Karlı", "Yağmurlu", "Rüzgarlı"], "correct_index": 2 },
      { "id": "c02", "prompt_tr": "Ne yapmayı planlıyorlar?", "options_tr": ["Park", "Kino", "Strand", "Sport"], "correct_index": 1 }
    ]
  },
  {
    "id": "d_a2_06",
