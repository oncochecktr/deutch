[
  {
    "id": "d_a2_01",
    "level": "A2",
    "title_de": "Am Bahnhof",
    "title_tr": "Tren istasyonunda",
    "theme": "Reisen · Verspätung",
    "source": "seed",
    "lines": [
      { "id": "l01", "speaker": "Reisende", "kind": "dialogue", "text_de": "Entschuldigung, wo ist Gleis fünf?", "text_tr": "Affedersiniz, beş numaralı peron nerede?" },
      { "id": "l02", "speaker": "Mitarbeiter", "kind": "dialogue", "text_de": "Gleis fünf ist rechts, unten.", "text_tr": "Beş numaralı peron sağda, aşağıda." },
      { "id": "l03", "speaker": "Reisende", "kind": "dialogue", "text_de": "Danke. Ist der Zug pünktlich?", "text_tr": "Teşekkürler. Tren zamanında mı?" },
      { "id": "l04", "speaker": "Mitarbeiter", "kind": "dialogue", "text_de": "Nein, er hat zwanzig Minuten Verspätung.", "text_tr": "Hayır, yirmi dakika gecikmesi var." },
      { "id": "l05", "speaker": "Reisende", "kind": "dialogue", "text_de": "Oh nein! Ich habe einen Termin um drei Uhr.", "text_tr": "Ah hayır! Saat üçte randevum var." },
      { "id": "l06", "speaker": "Mitarbeiter", "kind": "dialogue", "text_de": "Der Zug kommt um halb drei an.", "text_tr": "Tren iki buçukta varır." },
      { "id": "l07", "speaker": "Reisende", "kind": "dialogue", "text_de": "Gut, dann schaffe ich es noch.", "text_tr": "Tamam, o zaman yetişirim." }
    ],
    "comprehension": [
      { "id": "c01", "prompt_tr": "Trenin gecikmesi ne kadar?", "options_tr": ["10 dk", "20 dk", "30 dk", "Yok"], "correct_index": 1 },
      { "id": "c02", "prompt_tr": "Peron nerede?", "options_tr": ["Links oben", "Rechts unten", "Mitte", "Draußen"], "correct_index": 1 }
    ]
  },
  {
    "id": "d_a2_02",
    "level": "A2",
    "title_de": "Beim Arzt",
    "title_tr": "Doktorda",
    "theme": "Gesundheit · Symptome",
    "source": "seed",
    "lines": [
      { "id": "l01", "speaker": "Arzt", "kind": "dialogue", "text_de": "Guten Tag. Was fehlt Ihnen?", "text_tr": "İyi günler. Neyiniz var?" },
      { "id": "l02", "speaker": "Patient", "kind": "dialogue", "text_de": "Ich habe seit drei Tagen Kopfschmerzen.", "text_tr": "Üç gündür baş ağrım var." },
      { "id": "l03", "speaker": "Arzt", "kind": "dialogue", "text_de": "Haben Sie auch Fieber?", "text_tr": "Ateşiniz de var mı?" },
      { "id": "l04", "speaker": "Patient", "kind": "dialogue", "text_de": "Ja, ein bisschen.", "text_tr": "Evet, biraz." },
      { "id": "l05", "speaker": "Arzt", "kind": "dialogue", "text_de": "Sie sollten sich ausruhen und viel trinken.", "text_tr": "Dinlenmeli ve bol su içmelisiniz." },
      { "id": "l06", "speaker": "Arzt", "kind": "dialogue", "text_de": "Ich schreibe Ihnen ein Rezept.", "text_tr": "Size reçete yazıyorum." },
      { "id": "l07", "speaker": "Patient", "kind": "dialogue", "text_de": "Vielen Dank, Herr Doktor.", "text_tr": "Çok teşekkürler doktor bey." }
    ],
    "comprehension": [
      { "id": "c01", "prompt_tr": "Hasta ne şikayet ediyor?", "options_tr": ["Karın ağrısı", "Baş ağrısı", "Boğaz", "Sırt"], "correct_index": 1 },
      { "id": "c02", "prompt_tr": "Doktor ne öneriyor?", "options_tr": ["Spor", "Dinlenme", "İş", "Seyahat"], "correct_index": 1 }
    ]
  },
  {
    "id": "d_a2_03",
    "level": "A2",
    "title_de": "Im Bewerbungsgespräch",
    "title_tr": "İş görüşmesinde",
    "theme": "Beruf · Perfekt",
    "source": "seed",
    "lines": [
      { "id": "l01", "speaker": "Chef", "kind": "dialogue", "text_de": "Erzählen Sie bitte von Ihrer Erfahrung.", "text_tr": "Lütfen deneyiminizden bahsedin." },
      { "id": "l02", "speaker": "Bewerber", "kind": "dialogue", "text_de": "Ich habe fünf Jahre in einem Lager gearbeitet.", "text_tr": "Beş yıl bir depoda çalıştım." },
      { "id": "l03", "speaker": "Chef", "kind": "dialogue", "text_de": "Warum möchten Sie wechseln?", "text_tr": "Neden değiştirmek istiyorsunuz?" },
      { "id": "l04", "speaker": "Bewerber", "kind": "dialogue", "text_de": "Ich möchte mehr Verantwortung.", "text_tr": "Daha fazla sorumluluk istiyorum." },
      { "id": "l05", "speaker": "Chef", "kind": "dialogue", "text_de": "Gut. Wann können Sie anfangen?", "text_tr": "Güzel. Ne zaman başlayabilirsiniz?" },
      { "id": "l06", "speaker": "Bewerber", "kind": "dialogue", "text_de": "Ab nächsten Monat.", "text_tr": "Gelecek aydan itibaren." }
    ],
    "comprehension": [
      { "id": "c01", "prompt_tr": "Aday kaç yıl depoda çalışmış?", "options_tr": ["2", "3", "5", "10"], "correct_index": 2 }
    ]
  },
  {
    "id": "d_a2_04",
    "level": "A2",
    "title_de": "Im Hotel",
