      { "id": "l03", "speaker": "Mehmet", "kind": "dialogue", "text_de": "Gehen wir etwas trinken?", "text_tr": "Bir şeyler içmeye gidelim mi?" },
      { "id": "l04", "speaker": "Anna", "kind": "dialogue", "text_de": "Gern! Ich kenne ein gutes Café.", "text_tr": "Memnuniyetle! İyi bir kafe biliyorum." },
