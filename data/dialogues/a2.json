    "lines": [
      { "id": "l01", "speaker": "Kundin", "kind": "dialogue", "text_de": "Guten Tag. Ich möchte diese Jacke umtauschen.", "text_tr": "İyi günler. Bu ceketi değiştirmek istiyorum." },
      { "id": "l02", "speaker": "Verkäufer", "kind": "dialogue", "text_de": "Was ist das Problem?", "text_tr": "Sorun ne?" },
      { "id": "l03", "speaker": "Kundin", "kind": "dialogue", "text_de": "Sie ist zu klein. Haben Sie Größe M?", "text_tr": "Çok küçük. M beden var mı?" },
      { "id": "l04", "speaker": "Verkäufer", "kind": "dialogue", "text_de": "Ja, einen Moment bitte.", "text_tr": "Evet, bir dakika lütfen." },
      { "id": "l05", "speaker": "Verkäufer", "kind": "dialogue", "text_de": "Hier, Größe M. Passt das?", "text_tr": "Buyurun, M beden. Uyar mı?" },
      { "id": "l06", "speaker": "Kundin", "kind": "dialogue", "text_de": "Ja, perfekt. Danke!", "text_tr": "Evet, mükemmel. Teşekkürler!" }
    ],
    "comprehension": [
      { "id": "c01", "prompt_tr": "Müşteri ne istiyor?", "options_tr": ["İade", "Değişim", "İndirim", "Yeni ürün"], "correct_index": 1 }
    ]
  },
  {
