{
  "name": "german-coach",
  "version": "0.1.0",
  "private": true,
  "description": "Goethe A1/A2/B1 sınav hazırlık ve Almanca öğrenme platformu",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/web",
    "build": "npm run build --workspace=apps/web",
    "start": "npm run start --workspace=apps/web",
    "vocab": "node scripts/build-a1-500.mjs",
    "timur": "node scripts/build-timur.mjs",
    "goethe": "node scripts/build-goethe-a1-bank.mjs",
    "audio": "node scripts/generate-audio.mjs",
    "audit:articles": "node scripts/audit-a1-articles.mjs",
    "seed:articles": "node scripts/seed-article-reference.mjs",
    "build:patterns": "node scripts/build-a1-patterns.mjs",
    "build:conjugation": "node scripts/build-a1-conjugation.mjs",
    "build:possessives": "node scripts/build-a1-possessives.mjs",
    "build:articles": "node scripts/build-a1-articles.mjs",
    "build:dativ": "node scripts/build-a1-dativ.mjs",
    "build:negation": "node scripts/build-a1-negation.mjs",
    "build:prepositions": "node scripts/build-a1-prepositions.mjs",
    "patch:grammar": "node scripts/patch-a1-grammar-complete.mjs",
    "patch:word-order": "node scripts/patch-a1-word-order.mjs",
    "patch:satz-questions": "node scripts/patch-a1-satz-questions.mjs",
    "build:word-order": "node scripts/build-a1-word-order.mjs",
    "build:grundlagen": "npm run build:word-order && npm run build:possessives && npm run build:articles && npm run build:dativ && npm run build:negation && npm run build:prepositions && npm run build:conjugation && npm run patch:grammar && npm run patch:word-order && npm run patch:satz-questions",
    "brand": "node scripts/build-brand-assets.mjs"
  },
  "devDependencies": {
    "msedge-tts": "^2.0.5",
    "sharp": "^0.33.5"
  }
}
